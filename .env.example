# RunPod (for GPU provisioning — training, eval, deployment)
OCLT_RUNPOD_API_KEY=your_runpod_api_key

# OpenAI (for dataset generation + LLM judge evaluation)
OCLT_OPENAI_API_KEY=your_openai_api_key

# HuggingFace (for model/dataset/worker script storage)
OCLT_HF_TOKEN=your_hf_token
OCLT_HF_USERNAME=your_hf_username

# Optional: RunPod network volume for shared storage across pods
# OCLT_RUNPOD_VOLUME_ID=your_volume_id

# Public URL of this backend (so RunPod workers can POST status updates)
# Use an ngrok URL or your server's public address
# OCLT_PUBLIC_URL=https://your-server.com
